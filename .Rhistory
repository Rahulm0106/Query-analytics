knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
library(readr)
library(dplyr)
library(tidyr)
library(moments)
library(knitr)
raw_dir <- "../data/raw"
range_q  <- read_csv(file.path(raw_dir, "Range-Queries-Aggregates.csv"),
show_col_types = FALSE) %>%
select(-1) %>%                                # drop unnamed index col
rename(X = x, Y = y, X_range = x_range, Y_range = y_range,
Count = count, SUM = sum_, AVG = avg)
radius_q <- read_csv(file.path(raw_dir, "Radius-Queries.csv"),
col_names = c("X", "Y", "R"),
show_col_types = FALSE)
radius_c <- read_csv(file.path(raw_dir, "Radius-Queries-Count.csv"),
col_names = c("X", "Y", "R", "Count"),
show_col_types = FALSE)
tibble(
dataset = c("range_queries", "radius_queries", "radius_count"),
rows    = c(nrow(range_q), nrow(radius_q), nrow(radius_c)),
expected = c(200000L, 50000L, 10000L)
) %>% mutate(match = rows == expected) %>% kable()
bind_rows(
range_q  %>% summarise(across(everything(), ~sum(is.na(.)))) %>% mutate(dataset = "range_queries"),
radius_q %>% summarise(across(everything(), ~sum(is.na(.)))) %>% mutate(dataset = "radius_queries"),
radius_c %>% summarise(across(everything(), ~sum(is.na(.)))) %>% mutate(dataset = "radius_count")
) %>% select(dataset, everything()) %>% kable(caption = "Null counts per column")
range_q <- range_q %>%
mutate(AVG = ifelse(is.na(AVG) & Count == 0, 0, AVG))
stopifnot(sum(is.na(range_q)) == 0)
describe_one <- function(df, name) {
df %>% summarise(across(where(is.numeric),
list(min = ~min(.x), max = ~max(.x),
mean = ~mean(.x), median = ~median(.x),
sd = ~sd(.x),
skew = ~moments::skewness(.x),
kurt = ~moments::kurtosis(.x)))) %>%
pivot_longer(everything(),
names_to = c("column", ".value"),
names_pattern = "(.*)_(.*)") %>%
mutate(dataset = name, .before = 1)
}
desc_all <- bind_rows(
describe_one(range_q,  "range_queries"),
describe_one(radius_q, "radius_queries"),
describe_one(radius_c, "radius_count")
)
kable(desc_all, digits = 4, caption = "Min / max / mean / median / SD / skew / kurtosis")
dedupe <- function(df) {
before <- nrow(df); df <- distinct(df); after <- nrow(df)
tibble(before = before, after = after,
removed = before - after,
retention = after / before)
}
dedupe_report <- bind_rows(
dedupe(range_q)  %>% mutate(dataset = "range_queries"),
dedupe(radius_q) %>% mutate(dataset = "radius_queries"),
dedupe(radius_c) %>% mutate(dataset = "radius_count")
) %>% select(dataset, everything())
kable(dedupe_report, digits = 5, caption = "Duplicate removal — 100% retention across all three files")
